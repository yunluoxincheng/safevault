    <!-- 教育提示 -->
    <string name="migration_education_title">什么是加密算法？</string>
    <string name="migration_education_intro">加密算法是保护您数据安全的核心技术。SafeVault 使用端到端加密，意味着只有您和接收方可以解密数据，服务器无法访问。</string>

    <string name="migration_education_rsa_title">RSA-2048 (旧版本)</string>
    <string name="migration_education_rsa_desc">传统但安全的算法，被广泛使用。缺点是密钥尺寸大，速度较慢。</string>

    <string name="migration_education_x25519_title">X25519/Ed25519 (新版本)</string>
    <string name="migration_education_x25519_desc">现代椭圆曲线算法，行业标准（Signal、WhatsApp 等使用）。速度更快，密钥更小，安全性更强。</string>

    <!-- 兼容性说明 -->
    <string name="migration_compatibility_title">兼容性说明</string>
    <string name="migration_compatibility_desc">迁移后您仍然可以与使用旧版本的用户分享密码。系统会自动选择双方都支持的协议版本。</string>
    <string name="migration_compatibility_both_v3">双方都是 v3.0 → 使用 X25519/Ed25519（最优）</string>
    <string name="migration_compatibility_mixed_v2">一方是 v2.0 → 使用 RSA（兼容）</string>

    <!-- 常见问题 -->
    <string name="migration_faq_title">常见问题</string>

    <string name="migration_faq_q1">迁移会删除我的密码吗？</string>
    <string name="migration_faq_a1">不会。迁移只是生成新的加密密钥对，所有密码数据保持不变。</string>

    <string name="migration_faq_q2">迁移需要多长时间？</string>
    <string name="migration_faq_a2">通常需要 1 秒。迁移只是生成密钥并上传，不需要加密/解密现有数据。</string>

    <string name="migration_faq_q3">迁移失败怎么办？</string>
    <string name="migration_faq_a3">迁移是幂等的，失败后可以重试。旧密钥不会被删除，可以安全回滚。</string>

    <string name="migration_faq_q4">必须迁移吗？</string>
    <string name="migration_faq_a4">不是必须的。旧版本将继续正常工作，但无法享受新算法的性能优势。</string>

    <string name="migration_faq_q5">迁移后还能和旧版本用户分享吗？</string>
    <string name="migration_faq_a5">可以。系统会自动检测对方的加密算法版本，使用双方都支持的协议。</string>


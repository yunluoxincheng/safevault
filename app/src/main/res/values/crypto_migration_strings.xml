    <!-- 迁移详情 -->
    <string name="migration_details_title">关于新加密算法</string>
    <string name="migration_details_description">SafeVault v3.6.0 引入了现代椭圆曲线加密算法 X25519 和 Ed25519，这是业界领先的安全标准。</string>

    <string name="migration_details_x25519_title">X25519 密钥交换</string>
    <string name="migration_details_x25519_desc">用于安全地交换密钥，支持前向保密。每次分享使用新的临时密钥，确保即使长期私钥泄露，历史分享仍安全。</string>

    <string name="migration_details_ed25519_title">Ed25519 数字签名</string>
    <string name="migration_details_ed25519_desc">用于验证发送方身份。比传统 RSA 签名快 100 倍，同时提供更强的安全性。</string>

    <string name="migration_details_hkdf_title">HKDF 密钥派生</string>
    <string name="migration_details_hkdf_desc">从 ECDH 共享密钥派生 AES 密钥，同时混合双方身份，防止密钥混淆攻击。</string>


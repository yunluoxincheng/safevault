<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".ui.EditPasswordFragment">

    <!-- 加载覆盖层 -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/loading_overlay_background"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true" />

    </FrameLayout>

    <!-- 内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 基本信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Modern.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 卡片标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="基本信息"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        android:layout_marginBottom="16dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="4dp" />

                    <!-- 标题输入框 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/title_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/title"
                        app:startIconDrawable="@drawable/ic_edit">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/title_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 用户名输入框 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/username_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:hint="@string/username"
                        app:startIconDrawable="@drawable/ic_person">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/username_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 密码卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Modern.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 卡片标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="密码"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        android:layout_marginBottom="16dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="4dp" />

                    <!-- 密码输入框 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/password_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact.Password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/password"
                        app:startIconDrawable="@drawable/ic_password">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/password_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodyLarge"
                            android:fontFamily="monospace" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 分段式密码强度指示器 -->
                    <LinearLayout
                        android:id="@+id/password_strength_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="密码强度"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant" />

                            <TextView
                                android:id="@+id/password_strength_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textStyle="bold"
                                android:textSize="14sp"
                                tools:text="强" />

                        </LinearLayout>

                        <!-- 分段式强度条 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:weightSum="4">

                            <View
                                android:id="@+id/strength_bar_1"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@color/strength_weak"
                                android:alpha="0.3" />

                            <View
                                android:id="@+id/strength_bar_2"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:background="@color/strength_medium"
                                android:alpha="0.3" />

                            <View
                                android:id="@+id/strength_bar_3"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:background="@color/strength_strong"
                                android:alpha="0.3" />

                            <View
                                android:id="@+id/strength_bar_4"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:background="@color/strength_very_strong"
                                android:alpha="0.3" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 生成密码按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_generate_password"
                        style="@style/Widget.Material3.Button.OutlinedButton.Modern.Small"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:text="@string/generate_password"
                        app:icon="@drawable/ic_autorenew" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 详细信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Modern.Flat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 卡片标题 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="详细信息"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        android:layout_marginBottom="16dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="4dp" />

                    <!-- URL输入框 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/url_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:hint="@string/url"
                        app:startIconDrawable="@drawable/ic_public">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/url_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodyLarge" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 备注输入框 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/notes_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/notes">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/notes_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:maxLines="5"
                            android:minLines="2"
                            android:textAppearance="?attr/textAppearanceBodyMedium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 标签输入区域 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tags"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="4dp" />

                    <!-- 已添加的标签 ChipGroup -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/tags_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="8dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="4dp" />

                    <!-- 添加标签输入区域 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tag_input_layout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Modern.Compact"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/tag_hint"
                            app:endIconMode="clear_text">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/tag_input_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:maxLines="1"
                                android:imeOptions="actionDone"
                                android:textAppearance="?attr/textAppearanceBodyMedium" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_add_tag"
                            style="@style/Widget.Material3.Button.Icon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@string/add_tag"
                            app:icon="@android:drawable/ic_input_add"
                            app:iconSize="20dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 保存按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/Widget.Material3.Button.Modern"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="8dp"
                android:enabled="false"
                android:text="@string/save_password"
                app:icon="@drawable/ic_save"
                app:iconGravity="textEnd"
                app:iconSize="20dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
